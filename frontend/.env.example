# ── Required ──────────────────────────────────────────
# Contract address from: cd contract && npm run deploy
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddress

# Get free at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Ritual Chain public RPC (no change needed)
NEXT_PUBLIC_RITUAL_RPC_URL=https://rpc.ritualfoundation.org

# Get free at https://console.groq.com — SERVER SIDE ONLY, never exposed to client
GROQ_API_KEY=gsk_your_groq_api_key

# ── Vercel KV (for storing Siggy's narrations) ────────
# Auto-filled by Vercel when you add a KV store to your project
# For local dev: leave blank — narrations will work live but won't persist on refresh
KV_REST_API_URL=
KV_REST_API_TOKEN=
